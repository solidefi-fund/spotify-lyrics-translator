<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Bottom Sheet Lyrics Panel -->
    <LinearLayout
        android:id="@+id/layoutMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_background"
        android:elevation="8dp">

        <!-- Header: "Lyrics" title + action buttons -->
        <RelativeLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@android:color/transparent"
            android:paddingStart="20dp"
            android:paddingEnd="12dp">

            <!-- "Lyrics" Label -->
            <TextView
                android:id="@+id/tvLyricsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Lyrics"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Right-side action buttons -->
            <LinearLayout
                android:id="@+id/layoutActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <!-- Share Button -->
                <ImageButton
                    android:id="@+id/btnShare"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/circle_button_background"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="#FFFFFF"
                    android:layout_marginEnd="8dp" />

                <!-- Minimize Button (down chevron) -->
                <ImageButton
                    android:id="@+id/btnMinimize"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/circle_button_background"
                    android:src="@drawable/ic_chevron_down"
                    android:layout_marginEnd="8dp" />

                <!-- Close Button -->
                <ImageButton
                    android:id="@+id/btnClose"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/circle_button_background"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#FFFFFF" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Subtle divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#20FFFFFF" />

        <!-- Scrollable Lyrics List -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent">

            <ListView
                android:id="@+id/lvLyrics"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:scrollbars="none"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"
                android:background="@android:color/transparent" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Waiting for playback..."
                android:textColor="#80FFFFFF"
                android:textSize="15sp"
                android:textStyle="italic" />
        </FrameLayout>

        <!-- Hidden track info views (kept for compatibility, not shown) -->
        <TextView
            android:id="@+id/tvTrackTitle"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvTrackArtist"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Floating Lyrics Pill (Visible when minimized) -->
    <LinearLayout
        android:id="@+id/layoutBubble"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="96dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bubble_background"
        android:visibility="gone"
        android:elevation="10dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="4dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <!-- Lyric + Translation stacked -->
        <LinearLayout
            android:id="@+id/layoutBubbleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBubbleLyric"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="&#9834;"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:maxLines="3"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvBubbleTranslation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#C8A84B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="3"
                android:ellipsize="end"
                android:layout_marginTop="2dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="4dp"
            android:background="#30FFFFFF" />

        <!-- Expand (↑) button -->
        <ImageButton
            android:id="@+id/btnExpand"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_chevron_up"
            android:contentDescription="Expand" />

    </LinearLayout>

</FrameLayout>

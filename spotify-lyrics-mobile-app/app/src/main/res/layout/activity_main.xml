<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Icon / Logo area -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#9835;"
            android:textColor="#1DB954"
            android:textSize="48sp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lyrics Overlay"
            android:textColor="#111827"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Real-time Spotify Lyrics Translator"
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="36dp" />

        <!-- Card: Overlay Permission -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#F9FAFB"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1. Overlay Permission"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Required to draw the translated lyrics window over Spotify."
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnOverlayPermission"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Grant Overlay Permission"
                    android:backgroundTint="#1DB954"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card: Notification Access -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#F9FAFB"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2. Notification Access"
                    android:textColor="#111827"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Required to read the currently playing track from Spotify."
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnNotificationPermission"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Grant Notification Access"
                    android:backgroundTint="#1DB954"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>



        <!-- Status Text -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Permissions required"
            android:textColor="#EF4444"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Start/Stop Service Button -->
        <Button
            android:id="@+id/btnToggleService"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Start Overlay Service"
            android:backgroundTint="#111827"
            android:textColor="#FFFFFF"
            android:enabled="false"
            android:textSize="15sp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
